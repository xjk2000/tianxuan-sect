#!/usr/bin/env bash
# SessionStart hook for 天玄宗 plugin
# 在每次会话开始时注入天玄宗使用说明 + 道场回忆（历史观照与宗门记载）

set -euo pipefail

# 确定插件根目录
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# 检查是否已初始化天玄宗
warning_message=""
if [ ! -d "天玄宗" ]; then
    warning_message="\n\n<important-reminder>💡 **提示**: 项目尚未初始化天玄宗。请使用 \`/init-tianxuan\` 命令初始化项目结构。</important-reminder>"
fi

# ===== 道场回忆：注入跨会话历史记忆 =====
memory_section=""
if [ -d "天玄宗" ]; then
    SUMMARIES_FILE="天玄宗/宗门记载/SUMMARIES.md"
    OBSERVATIONS_FILE="天玄宗/道行观照/OBSERVATIONS.md"
    summaries_content=""
    observations_content=""
    obs_total=0
    summary_total=0

    # 宗门记载：精确读取最近 3 条完整内容（按 ## 📜 记载 分割）
    if [ -f "$SUMMARIES_FILE" ] && [ -s "$SUMMARIES_FILE" ]; then
        summary_total=$(grep -c "^## 📜 记载" "$SUMMARIES_FILE" 2>/dev/null || echo "0")
        if [ "$summary_total" -gt 0 ]; then
            summaries_content=$(awk '
                /^## 📜 记载/ { if (block!="") { n++; blocks[n]=block }; block=$0; next }
                { if (block!="") block=block"\n"$0 }
                END { if (block!="") { n++; blocks[n]=block };
                      start=(n>3)?n-2:1;
                      for(i=start;i<=n;i++) { print blocks[i]; print "---" } }
            ' "$SUMMARIES_FILE" 2>/dev/null || echo "")
        fi
    fi

    # 道行观照：读取总数 + 最近 20 条的标题索引行（极省 token）
    if [ -f "$OBSERVATIONS_FILE" ] && [ -s "$OBSERVATIONS_FILE" ]; then
        obs_total=$(grep -c "^## #" "$OBSERVATIONS_FILE" 2>/dev/null || echo "0")
        if [ "$obs_total" -gt 0 ]; then
            # 只取标题行（## #编号 · 日期 · 长老 · 类型）和下一行（**标题**）
            observations_content=$(grep -A1 "^## #" "$OBSERVATIONS_FILE" 2>/dev/null \
                | grep -v "^--$" \
                | tail -n 40 \
                || echo "")
        fi
    fi

    if [ -n "$summaries_content" ] || [ "$obs_total" -gt 0 ]; then
        memory_section="\n\n## 🏯 道场回忆（跨会话持久记忆）\n\n"
        memory_section="${memory_section}> 宗门记忆库：共 **${obs_total}** 条道行观照，**${summary_total}** 条宗门记载\n"
        if [ -n "$summaries_content" ]; then
            memory_section="${memory_section}\n### 📜 近期宗门记载（最近 3 条）\n\n${summaries_content}\n"
        fi
        if [ -n "$observations_content" ]; then
            memory_section="${memory_section}\n### 🔮 道行观照索引（最近 20 条标题）\n\n${observations_content}\n"
        fi
        memory_section="${memory_section}\n> 💡 使用 **天玄记忆诀** skill 可按关键词深度检索\n"
    fi
fi

# 读取天玄宗使用说明
tianxuan_intro=$(cat <<'EOF'
# 天玄宗修仙宗门多 Agent 协作系统

你现在拥有天玄宗的力量！这是一个专业的多 Agent 协作开发系统。

## 核心角色

- **宗主** - 需求探索、任务拆分、调度协调、验收归档
- **藏经阁长老** - 知识管理、文档总结、经验沉淀
- **丹堂长老** - 数据查询、日志分析、环境诊断
- **阵堂长老** - 后端开发（任何后端技术栈）
- **器堂长老** - 前端开发（任何前端技术栈）
- **执法堂长老** - 测试验收、质量把关、缺陷诊断

## 核心原则

1. **HARD-GATE** - 宗主在用户确认设计前，禁止创建任务
2. **No Placeholders** - 任务定义必须完整，禁止 "TBD"、"待定"
3. **藏经阁优先** - 各堂开始前必须先查询藏经阁
4. **Self-Review** - 各堂完成后执行自检清单
5. **两阶段审查** - 执法堂先验证功能，再验证质量
6. **3次失败机制** - 失败3次后质疑架构设计

## 快速开始

### 1. 初始化项目
\`\`\`bash
/init-tianxuan
\`\`\`

### 2. 下达任务
\`\`\`
@宗主 我想实现一个用户管理系统
\`\`\`

### 3. 宗主会引导你
- 提问了解需求
- 委派藏经阁调研
- 提出设计方案
- 分段展示设计
- 等待你确认

### 4. 确认后开始协作
- 藏经阁：调研并存储文档
- 阵堂：实现后端
- 器堂：实现前端
- 执法堂：两阶段测试
- 宗主：验收归档

## 可用技能

- **需求探索术** - 宗主的需求探索技能
- **藏经阁优先法** - 强制查询藏经阁
- **天玄记忆诀** - 跨会话历史记忆检索（三层工作流）
- **自检心法** - 各堂的自检清单
- **两阶段审查法** - 执法堂的测试流程
- **系统化调试术** - 执法堂的调试方法
- **Git工作流** - 分支管理规范
- **代码审查诀** - 代码审查清单
- **文档生成法** - 文档自动生成

## 重要提醒

- ✅ 始终遵循 HARD-GATE 原则
- ✅ 任务定义必须完整（No Placeholders）
- ✅ 各堂必须先查询藏经阁
- ✅ 完成后必须执行 Self-Review
- ✅ **各堂完成实质工作后必须生成 `<道行观照>` XML 并通知藏经阁存档**
- ✅ **任务归档时宗主必须生成 `<宗门记载>` XML 并通知藏经阁存入记忆库**
- ✅ **开始新任务或继续任务前，先用天玄记忆诀检索历史上下文**
- ❌ 不要跳过任何步骤
- ❌ 不要让其他堂自行查询官方文档（必须由藏经阁）

详细文档请查看项目 README.md
EOF
)

# JSON 转义函数
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

tianxuan_intro_escaped=$(escape_for_json "$tianxuan_intro")
warning_escaped=$(escape_for_json "$warning_message")
memory_escaped=$(escape_for_json "$memory_section")
session_context="<EXTREMELY_IMPORTANT>\n你拥有天玄宗的力量！\n\n${tianxuan_intro_escaped}${memory_escaped}\n\n${warning_escaped}\n</EXTREMELY_IMPORTANT>"

# 输出上下文注入
# 支持 Claude Code 和 Cursor
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  # Cursor 平台
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  # Claude Code 平台
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  # 其他平台
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
